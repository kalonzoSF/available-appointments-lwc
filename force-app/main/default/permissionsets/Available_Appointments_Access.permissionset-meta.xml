<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Available Appointments Access</label>
    <description>Grants access to the Available Appointments LWC and its Apex controller, including required object and field permissions for Field Service objects.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>AvailableAppointmentsController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- ===== Object Permissions ===== -->

    <!-- ServiceAppointment: Read + Edit (controller updates Status, SchedStartTime, SchedEndTime) -->
    <objectPermissions>
        <object>ServiceAppointment</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- AssignedResource: Read + Create (controller inserts AssignedResource on self-assign) -->
    <objectPermissions>
        <object>AssignedResource</object>
        <allowRead>true</allowRead>
        <allowCreate>true</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- ServiceResource: Read -->
    <objectPermissions>
        <object>ServiceResource</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- ServiceTerritoryMember: Read -->
    <objectPermissions>
        <object>ServiceTerritoryMember</object>
