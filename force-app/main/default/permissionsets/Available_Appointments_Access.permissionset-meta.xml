<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Available Appointments Access</label>
    <description>Grants access to the Available Appointments LWC and its Apex controller, including required object and field permissions for Field Service objects.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <!-- Apex Class Access -->
    <classAccesses>
        <apexClass>AvailableAppointmentsController</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- ===== Object Permissions ===== -->

    <!-- ServiceAppointment: Read + Edit (controller updates Status, SchedStartTime, SchedEndTime) -->
    <objectPermissions>
        <object>ServiceAppointment</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>true</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- AssignedResource: Read + Create (controller inserts AssignedResource on self-assign) -->
    <objectPermissions>
        <object>AssignedResource</object>
        <allowRead>true</allowRead>
        <allowCreate>true</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- ServiceResource: Read -->
    <objectPermissions>
        <object>ServiceResource</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- ServiceTerritoryMember: Read -->
    <objectPermissions>
        <object>ServiceTerritoryMember</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- ServiceResourceSkill: Read -->
    <objectPermissions>
        <object>ServiceResourceSkill</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- ServiceCrewMember: Read -->
    <objectPermissions>
        <object>ServiceCrewMember</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- WorkOrder: Read -->
    <objectPermissions>
        <object>WorkOrder</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- SkillRequirement: Read -->
    <objectPermissions>
        <object>SkillRequirement</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- Location: Read (required dependency for ProductItem) -->
    <objectPermissions>
        <object>Location</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- Product2: Read (required dependency for ProductItem) -->
    <objectPermissions>
        <object>Product2</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- ProductItem: Read -->
    <objectPermissions>
        <object>ProductItem</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- ProductRequired: Read -->
    <objectPermissions>
        <object>ProductRequired</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <!-- ===== Field Permissions (nillable fields only — required/compound fields excluded) ===== -->

    <!-- ServiceResource -->
    <fieldPermissions>
        <field>ServiceResource.LocationId</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ServiceResource.RelatedRecordId</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>

    <!-- ServiceAppointment (Read) -->
    <fieldPermissions>
        <field>ServiceAppointment.Subject</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ServiceAppointment.Duration</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ServiceAppointment.DurationType</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ServiceAppointment.ServiceTerritoryId</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ServiceAppointment.ParentRecordId</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ServiceAppointment.FSL__GanttLabel__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <!-- ServiceAppointment (Read + Edit for self-assign) -->
    <fieldPermissions>
        <field>ServiceAppointment.Status</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ServiceAppointment.SchedStartTime</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>ServiceAppointment.SchedEndTime</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <!-- WorkOrder -->
    <fieldPermissions>
        <field>WorkOrder.WorkTypeId</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
</PermissionSet>
